---
/**
 * SocialLinks Component
 *
 * Displays social media links with icons.
 * Used in Footer, About page, and other locations.
 *
 * @see .trellis/spec/frontend/components.md - Component design patterns
 */

interface Props {
  /** Link size */
  size?: 'sm' | 'md' | 'lg';
  /** Show labels alongside icons */
  showLabels?: boolean;
  /** Additional CSS classes */
  class?: string;
}

const {
  size = 'md',
  showLabels = false,
  class: className,
}: Props = Astro.props;

// Size styles for icons
const iconSizes: Record<string, string> = {
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
};

// Size styles for container
const containerSizes: Record<string, string> = {
  sm: 'gap-3',
  md: 'gap-4',
  lg: 'gap-5',
};
---

<div class:list={['flex items-center', containerSizes[size], className]}>
  {/* GitHub */}
  <a
    href="https://github.com"
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'inline-flex items-center gap-2',
      'text-foreground-tertiary hover:text-foreground',
      'transition-colors duration-200',
      'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-sm',
    ]}
    aria-label="GitHub"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class:list={[iconSizes[size]]}
      aria-hidden="true"
    >
      <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
      <path d="M9 18c-4.51 2-5-2-7-2" />
    </svg>
    {showLabels && <span class="text-sm font-medium">GitHub</span>}
  </a>

  {/* Twitter */}
  <a
    href="https://twitter.com"
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'inline-flex items-center gap-2',
      'text-foreground-tertiary hover:text-foreground',
      'transition-colors duration-200',
      'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-sm',
    ]}
    aria-label="Twitter"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class:list={[iconSizes[size]]}
      aria-hidden="true"
    >
      <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" />
    </svg>
    {showLabels && <span class="text-sm font-medium">Twitter</span>}
  </a>

  {/* Email */}
  <a
    href="mailto:hello@example.com"
    class:list={[
      'inline-flex items-center gap-2',
      'text-foreground-tertiary hover:text-foreground',
      'transition-colors duration-200',
      'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-sm',
    ]}
    aria-label="Email"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class:list={[iconSizes[size]]}
      aria-hidden="true"
    >
      <rect width="20" height="16" x="2" y="4" rx="2" />
      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
    </svg>
    {showLabels && <span class="text-sm font-medium">Email</span>}
  </a>
</div>
