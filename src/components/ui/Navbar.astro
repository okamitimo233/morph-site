---
/**
 * Navbar Component
 *
 * A responsive navigation bar with logo, links, search, and theme toggle.
 * Fixed at the top with scroll-based background blur effect.
 *
 * @see .trellis/spec/frontend/astro-integration.md - Astro + React integration
 * @see .trellis/spec/frontend/islands-architecture.md - Hydration strategies
 */

import ThemeToggle from '../islands/ThemeToggle';
import Container from './Container.astro';

interface Props {
  /** Current page path for active link highlighting */
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

// Navigation links
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/articles', label: 'Articles' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];

// Check if link is active
function isActive(href: string, current: string): boolean {
  if (href === '/') {
    return current === '/';
  }
  return current.startsWith(href);
}
---

<header
  id="navbar"
  data-current-path={currentPath}
  class="fixed top-0 left-0 right-0 z-[var(--z-fixed)]"
>
  <Container>
    <nav
      class="flex items-center justify-between h-16 md:h-20 transition-all duration-300"
      aria-label="Main navigation"
    >
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2 text-xl font-semibold font-display text-foreground hover:text-primary transition-colors"
        aria-label="Morph Blog - Home"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-primary"
          aria-hidden="true"
        >
          <path d="M12 2L2 7l10 5 10-5-10-5z" />
          <path d="m2 17 10 5 10-5" />
          <path d="m2 12 10 5 10-5" />
        </svg>
        <span>Morph</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-2 rounded-lg text-sm font-medium transition-colors',
              isActive(link.href, currentPath)
                ? 'text-foreground bg-selected'
                : 'text-foreground-secondary hover:text-foreground hover:bg-hover',
            ]}
            aria-current={isActive(link.href, currentPath) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right Section: Search + Theme Toggle -->
      <div class="flex items-center gap-2">
        <!-- Search Button (placeholder) -->
        <button
          type="button"
          class="flex items-center justify-center w-10 h-10 rounded-lg text-foreground-secondary hover:text-foreground hover:bg-hover transition-colors"
          aria-label="Search"
          disabled
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.3-4.3" />
          </svg>
        </button>

        <!-- Theme Toggle (React island) -->
        <ThemeToggle client:load />

        <!-- Mobile Menu Button -->
        <button
          type="button"
          id="mobile-menu-button"
          class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg text-foreground-secondary hover:text-foreground hover:bg-hover transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <!-- Hamburger Icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="menu-icon"
            aria-hidden="true"
          >
            <line x1="4" x2="20" y1="12" y2="12" />
            <line x1="4" x2="20" y1="6" y2="6" />
            <line x1="4" x2="20" y1="18" y2="18" />
          </svg>
          <!-- Close Icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="close-icon hidden"
            aria-hidden="true"
          >
            <path d="M18 6 6 18" />
            <path d="m6 6 12 12" />
          </svg>
        </button>
      </div>
    </nav>
  </Container>

  <!-- Mobile Navigation Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-surface border-t border-border"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <Container>
      <div class="py-4 space-y-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'block px-4 py-3 rounded-lg text-base font-medium transition-colors',
              isActive(link.href, currentPath)
                ? 'text-foreground bg-selected'
                : 'text-foreground-secondary hover:text-foreground hover:bg-hover',
            ]}
            aria-current={isActive(link.href, currentPath) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>
    </Container>
  </div>

  <!-- Navbar Background Overlay (for scroll effect) -->
  <div
    id="navbar-bg"
    class="absolute inset-0 -z-10 opacity-0 transition-opacity duration-300 pointer-events-none"
  >
    <div class="absolute inset-0 glass border-b border-border"></div>
  </div>
</header>

<!-- Add scroll behavior and mobile menu logic -->
<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = mobileMenuButton?.querySelector('.menu-icon');
  const closeIcon = mobileMenuButton?.querySelector('.close-icon');

  mobileMenuButton?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden');

    if (isOpen) {
      mobileMenu?.classList.remove('hidden');
      menuIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      mobileMenuButton.setAttribute('aria-expanded', 'true');
    } else {
      mobileMenu?.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      mobileMenuButton.setAttribute('aria-expanded', 'false');
    }
  });

  // Scroll-based navbar background
  const navbarBg = document.getElementById('navbar-bg');
  let ticking = false;

  function updateNavbarBg() {
    const scrollY = window.scrollY;

    if (scrollY > 20) {
      navbarBg?.classList.remove('opacity-0');
      navbarBg?.classList.add('opacity-100');
    } else {
      navbarBg?.classList.remove('opacity-100');
      navbarBg?.classList.add('opacity-0');
    }

    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(updateNavbarBg);
      ticking = true;
    }
  }, { passive: true });

  // Initial check
  updateNavbarBg();
</script>
