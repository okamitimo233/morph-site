---
/**
 * Article List Component
 *
 * Displays a grid of article cards with responsive layout.
 * Mobile: 1 column, Tablet: 2 columns, Desktop: 3 columns.
 *
 * @see .trellis/spec/frontend/components.md - Component design patterns
 * @see .trellis/spec/frontend/tailwind-css.md - Responsive grid patterns
 */

import { Image } from 'astro:assets';
import Card from '../ui/Card.astro';
import type { Article } from '../../data/mock';

interface Props {
  /** Articles to display */
  articles: Article[];
  /** Section title */
  title?: string;
  /** Section description */
  description?: string;
  /** Number of columns on desktop (1-4) */
  columns?: 1 | 2 | 3 | 4;
  /** Show view all link */
  showViewAll?: boolean;
  /** View all link URL */
  viewAllUrl?: string;
  /** View all link text */
  viewAllText?: string;
}

const {
  articles,
  title = 'Recent Articles',
  description = 'Explore my latest writings on web development, design, and technology',
  columns = 3,
  showViewAll = true,
  viewAllUrl = '/articles',
  viewAllText = 'View all articles',
} = Astro.props;

// Column classes for responsive grid
const columnClasses: Record<number, string> = {
  1: 'grid-cols-1',
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4',
};

/**
 * Format date to readable string
 */
function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---

<section class="py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-10 md:mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-3">{title}</h2>
      {description && (
        <p class="text-foreground-secondary max-w-2xl mx-auto">{description}</p>
      )}
    </div>

    <!-- Article Grid -->
    {articles.length > 0 ? (
      <div class:list={['grid gap-6', columnClasses[columns]]}>
        {articles.map((article) => (
          <Card padding="none" hoverable={true}>
            <!-- Card Image -->
            <div class="relative h-48 overflow-hidden">
              <Image
                src={article.coverImage}
                alt=""
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                width={400}
                height={200}
              />
              <!-- Category Badge -->
              <div class="absolute top-3 left-3">
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-background/90 backdrop-blur-sm text-foreground-secondary">
                  {article.category}
                </span>
              </div>
            </div>

            <!-- Card Content -->
            <div class="p-5">
              <!-- Title -->
              <h3 class="text-lg font-semibold text-foreground mb-2 line-clamp-2">
                <a
                  href={`/articles/${article.id}`}
                  class="hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded"
                >
                  {article.title}
                </a>
              </h3>

              <!-- Excerpt -->
              <p class="text-sm text-foreground-secondary line-clamp-2 mb-4">
                {article.excerpt}
              </p>

              <!-- Meta Info -->
              <div class="flex items-center justify-between text-xs text-foreground-tertiary">
                <time datetime={article.date}>
                  {formatDate(article.date)}
                </time>
                <span>{article.readingTime} min read</span>
              </div>

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5 mt-3">
                {article.tags.slice(0, 2).map((tag) => (
                  <span class="text-xs px-2 py-0.5 rounded bg-background-tertiary text-foreground-secondary">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </Card>
        ))}
      </div>
    ) : (
      <div class="text-center py-12 text-foreground-tertiary">
        No articles yet
      </div>
    )}

    <!-- View All Link -->
    {showViewAll && articles.length > 0 && (
      <div class="text-center mt-10">
        <a
          href={viewAllUrl}
          class="inline-flex items-center gap-2 text-primary hover:text-primary-hover font-medium transition-colors"
        >
          {viewAllText}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  /* Line clamp utility */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
