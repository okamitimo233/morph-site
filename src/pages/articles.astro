---
/**
 * Articles Page
 *
 * Displays all blog articles in a responsive grid layout.
 * Uses the reusable ArticleList component for consistent design.
 *
 * @see .trellis/spec/frontend/astro-routing.md - File-based routing
 * @see .trellis/spec/frontend/components.md - Component design patterns
 */

import Layout from '../layouts/Layout.astro';
import ArticleList from '../components/home/ArticleList.astro';
import Container from '../components/ui/Container.astro';
import { articles } from '../data/mock';

// Get unique categories for filter
const categories = [...new Set(articles.map((article) => article.category))];

// Get all articles sorted by date (newest first)
const allArticles = [...articles].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);
---

<Layout title="Articles | Morph Blog">
  <main id="main-content" class="pt-16 md:pt-20">
    <!-- Page Header -->
    <section class="py-12 md:py-16 border-b border-border">
      <Container>
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-4">
            Articles
          </h1>
          <p class="text-lg text-foreground-secondary leading-relaxed">
            Explore my writings on web development, design patterns, and the latest in frontend technology.
            From deep dives to quick tips, there's something for every developer.
          </p>
        </div>
      </Container>
    </section>

    <!-- Categories Filter (Visual only for now) -->
    <section class="py-6 border-b border-border bg-background-secondary/50">
      <Container>
        <div class="flex items-center gap-3 overflow-x-auto pb-2 -mb-2 scrollbar-hide">
          <span class="text-sm text-foreground-tertiary flex-shrink-0">Filter:</span>
          <button
            class="px-4 py-1.5 rounded-full text-sm font-medium bg-primary text-primary-foreground transition-colors flex-shrink-0"
          >
            All
          </button>
          {categories.map((category) => (
            <button
              class="px-4 py-1.5 rounded-full text-sm font-medium bg-background-tertiary text-foreground-secondary hover:bg-hover transition-colors flex-shrink-0"
            >
              {category}
            </button>
          ))}
        </div>
      </Container>
    </section>

    <!-- Article Stats -->
    <section class="py-6">
      <Container>
        <div class="flex items-center justify-between text-sm text-foreground-tertiary">
          <span>{allArticles.length} articles</span>
          <div class="flex items-center gap-4">
            <button class="flex items-center gap-1.5 hover:text-foreground transition-colors">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
              Sort by date
            </button>
          </div>
        </div>
      </Container>
    </section>

    <!-- Articles Grid -->
    <ArticleList articles={allArticles} title="" description="" showViewAll={false} columns={3} />

    <!-- Subscribe CTA -->
    <section class="py-16 md:py-24 bg-background-secondary/50">
      <Container size="md">
        <div class="text-center max-w-2xl mx-auto">
          <h2 class="text-2xl md:text-3xl font-bold text-foreground mb-4">
            Stay Updated
          </h2>
          <p class="text-foreground-secondary mb-8">
            Subscribe to get notified when I publish new articles. No spam, just quality content delivered to your inbox.
          </p>
          <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
            <input
              type="email"
              placeholder="Enter your email"
              required
              class="flex-1 px-4 py-3 rounded-lg bg-background border border-border text-foreground placeholder:text-foreground-tertiary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
            />
            <button
              type="submit"
              class="px-6 py-3 bg-primary text-primary-foreground rounded-lg font-medium transition-all hover:bg-primary-hover hover:shadow-glow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
            >
              Subscribe
            </button>
          </form>
        </div>
      </Container>
    </section>
  </main>
</Layout>

<style>
  /* Hide scrollbar for filter buttons */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
