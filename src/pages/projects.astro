---
/**
 * Projects Page
 *
 * Showcases personal projects with cards featuring
 * images, descriptions, and technology tags.
 *
 * @see .trellis/spec/frontend/astro-routing.md - File-based routing
 * @see .trellis/spec/frontend/components.md - Component design patterns
 */

import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Container from '../components/ui/Container.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import { getAllProjects } from '../data/mock';

const projects = getAllProjects();

// Group projects by status
const activeProjects = projects.filter((p) => p.status !== 'archived');
const archivedProjects = projects.filter((p) => p.status === 'archived');

// Status badge styles
const statusStyles: Record<string, string> = {
  completed: 'bg-success/10 text-success',
  'in-progress': 'bg-warning/10 text-warning',
  archived: 'bg-foreground-muted/10 text-foreground-muted',
};

const statusLabels: Record<string, string> = {
  completed: 'Completed',
  'in-progress': 'In Progress',
  archived: 'Archived',
};
---

<Layout title="Projects | Morph Blog">
  <main id="main-content" class="pt-16 md:pt-20">
    <!-- Page Header -->
    <section class="py-12 md:py-16 border-b border-border">
      <Container>
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-4">
            Projects
          </h1>
          <p class="text-lg text-foreground-secondary leading-relaxed">
            A collection of projects I've built, from web applications to tools and experiments.
            Each project represents a learning experience and a step forward in my journey.
          </p>
        </div>
      </Container>
    </section>

    <!-- Active Projects -->
    <section class="py-16 md:py-24">
      <Container>
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {activeProjects.map((project) => (
            <Card padding="none" hoverable={true}>
              <!-- Project Image -->
              <div class="relative h-48 overflow-hidden">
                <Image
                  src={project.coverImage}
                  alt=""
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  width={400}
                  height={200}
                />
                <!-- Status Badge -->
                <div class="absolute top-3 right-3">
                  <span class:list={['px-2.5 py-1 rounded-full text-xs font-medium', statusStyles[project.status]]}>
                    {statusLabels[project.status]}
                  </span>
                </div>
              </div>

              <!-- Project Content -->
              <div class="p-5">
                <div class="flex items-start justify-between gap-4 mb-3">
                  <h3 class="text-lg font-semibold text-foreground">
                    {project.title}
                  </h3>
                  <span class="text-sm text-foreground-tertiary flex-shrink-0">
                    {project.year}
                  </span>
                </div>

                <p class="text-sm text-foreground-secondary mb-4 line-clamp-2">
                  {project.description}
                </p>

                <!-- Technologies -->
                <div class="flex flex-wrap gap-1.5 mb-4">
                  {project.technologies.slice(0, 4).map((tech) => (
                    <span class="text-xs px-2 py-0.5 rounded bg-background-tertiary text-foreground-secondary">
                      {tech}
                    </span>
                  ))}
                  {project.technologies.length > 4 && (
                    <span class="text-xs px-2 py-0.5 text-foreground-tertiary">
                      +{project.technologies.length - 4}
                    </span>
                  )}
                </div>

                <!-- Links -->
                <div class="flex items-center gap-3 pt-4 border-t border-border">
                  {project.url && (
                    <a
                      href={project.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-1.5 text-sm text-primary hover:text-primary-hover transition-colors"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M15 3h6v6" />
                        <path d="M10 14 21 3" />
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                      </svg>
                      Live Demo
                    </a>
                  )}
                  {project.github && (
                    <a
                      href={project.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-1.5 text-sm text-foreground-secondary hover:text-foreground transition-colors"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                        <path d="M9 18c-4.51 2-5-2-7-2" />
                      </svg>
                      Source
                    </a>
                  )}
                  {!project.url && !project.github && (
                    <span class="text-sm text-foreground-tertiary">
                      Private project
                    </span>
                  )}
                </div>
              </div>
            </Card>
          ))}
        </div>
      </Container>
    </section>

    <!-- Archived Projects -->
    {archivedProjects.length > 0 && (
      <section class="py-16 md:py-24 bg-background-secondary/30">
        <Container>
          <div class="mb-8">
            <h2 class="text-2xl font-bold text-foreground mb-2">Archived Projects</h2>
            <p class="text-foreground-secondary">Older projects that are no longer actively maintained.</p>
          </div>

          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {archivedProjects.map((project) => (
              <div class="rounded-xl border border-border bg-surface p-5 opacity-75 hover:opacity-100 transition-opacity">
                <div class="flex items-start justify-between gap-4 mb-3">
                  <h3 class="text-lg font-semibold text-foreground">
                    {project.title}
                  </h3>
                  <span class="text-xs px-2 py-0.5 rounded-full bg-foreground-muted/10 text-foreground-muted">
                    {project.year}
                  </span>
                </div>

                <p class="text-sm text-foreground-secondary mb-4">
                  {project.description}
                </p>

                <div class="flex flex-wrap gap-1.5">
                  {project.technologies.map((tech) => (
                    <span class="text-xs px-2 py-0.5 rounded bg-background-tertiary text-foreground-tertiary">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </Container>
      </section>
    )}

    <!-- CTA Section -->
    <section class="py-16 md:py-24">
      <Container size="md">
        <div class="text-center space-y-6">
          <h2 class="text-2xl md:text-3xl font-bold text-foreground">
            Interested in Collaboration?
          </h2>
          <p class="text-foreground-secondary max-w-xl mx-auto">
            I'm always looking for interesting projects and opportunities to work with talented people.
            Feel free to reach out if you have something in mind.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <Button href="mailto:hello@morph-blog.dev" variant="primary" size="lg">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                slot="icon-left"
                aria-hidden="true"
              >
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
              Contact Me
            </Button>
            <Button href="https://github.com" target="_blank" variant="outline" size="lg">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                slot="icon-left"
                aria-hidden="true"
              >
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </svg>
              GitHub
            </Button>
          </div>
        </div>
      </Container>
    </section>
  </main>
</Layout>

<style>
  /* Line clamp utility */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
