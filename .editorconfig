# EditorConfig - https://editorconfig.org
# This file helps maintain consistent coding style across different editors and IDEs

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# TypeScript and JavaScript files
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# CSS and related files
[*.{css,scss,sass,less}]
indent_size = 2

# HTML and Astro files
[*.{html,astro}]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# YAML files
[*.{yaml,yml}]
indent_size = 2

# Makefile (requires tabs)
[Makefile]
indent_style = tab

# Package.json and similar config files
[{package.json,.prettierrc.json,.eslintrc.json}]
indent_size = 2
